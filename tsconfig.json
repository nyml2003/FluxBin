{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "useUnknownInCatchVariables": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@fluxbin/core": ["packages/core/src/index.ts"],
      "@fluxbin/client": ["packages/client/src/index.ts"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": ["packages/**/*.ts", "scripts/**/*.ts", "bench/**/*.ts", "vitest.config.ts"],
  "exclude": ["dist", "node_modules"]
}
