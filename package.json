{
  "name": "fluxbin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm --filter @fluxbin/core build && pnpm --filter @fluxbin/client build && pnpm --filter @fluxbin/transport-websocket build && pnpm --filter @fluxbin/devtools build && pnpm --filter @fluxbin/env-browser build && pnpm --filter @fluxbin/env-node build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "tsx scripts/run-vitest-with-coverage.ts",
    "bench": "tsx bench/index.ts",
    "example:basic-roundtrip": "tsx examples/basic-roundtrip/index.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.1.2",
    "eslint": "^9.25.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2"
  }
}
